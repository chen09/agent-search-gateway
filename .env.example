# Copy this file to .env before running Agent Search Gateway.
# See docs/ENVIRONMENT.md for full examples and per-runtime notes.

# Required by SearXNG. Generate with:
# openssl rand -hex 32
SEARXNG_SECRET=change-me-generate-with-openssl-rand-hex-32

# Protect the unified gateway API. Generate with:
# openssl rand -hex 32
RETRIEVAL_API_KEY=change-me-generate-with-openssl-rand-hex-32

# Comma-separated SearXNG base URLs. The gateway tries them in order.
SEARXNG_BASE_URLS=http://searxng:8080

# Host port for Docker Compose SearXNG. 8888 avoids common local nginx conflicts on 8080.
SEARXNG_HOST_PORT=8888

# Search provider order. Open-source/self-hosted providers are first by default.
# Tavily is skipped unless explicitly enabled below.
PROVIDER_ORDER=searxng,tavily

# Optional Tavily provider. Put the real key only in .env, never in git.
TAVILY_ENABLED=false
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_DAILY_CREDIT_LIMIT=50
TAVILY_SEARCH_DEPTH=basic

# Optional Brave provider placeholder. It is not implemented/enabled by default.
# Only enable after setting a real quota/budget guard.
BRAVE_ENABLED=false
BRAVE_API_KEY=
BRAVE_DAILY_CREDIT_LIMIT=0

# Optional LLM provider keys for future native summarization.
# The current MVP still uses SUMMARY_WEBHOOK_URL for summary handoff.
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# In-process response/content cache.
CACHE_ENABLED=true
SEARCH_CACHE_TTL_SECONDS=900
CONTENT_CACHE_TTL_SECONDS=86400

# Optional local reranker. Disabled by default because sentence-transformers
# pulls PyTorch. Install api/requirements-reranker.txt before enabling.
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_DEVICE=cpu

# Extraction settings.
MAX_RESULTS=8
EXTRACT_TOP_K=5
CONTENT_MAX_CHARS=12000
HTTP_TIMEOUT_SECONDS=15

# Optional fallback: self-hosted Jina Reader from the compose "reader" profile.
# If unset or unavailable, local trafilatura extraction is still used.
JINA_READER_BASE_URL=

# Optional hosted Jina Reader fallback. Not true zero-paid if you exceed free quota.
# JINA_READER_BASE_URL=https://r.jina.ai
# JINA_API_KEY=

# Optional summary handoff. Leave empty to return an extractive placeholder.
# Point this at your Cursor/Codex/MiniMax gateway later.
SUMMARY_WEBHOOK_URL=
