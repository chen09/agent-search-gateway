# Copy this file to .env before running Agent Search Gateway.

# Required by SearXNG. Generate with:
# openssl rand -hex 32
SEARXNG_SECRET=change-me-generate-with-openssl-rand-hex-32

# Protect the unified gateway API. Generate with:
# openssl rand -hex 32
RETRIEVAL_API_KEY=change-me-generate-with-openssl-rand-hex-32

# Comma-separated SearXNG base URLs. The gateway tries them in order.
SEARXNG_BASE_URLS=http://searxng:8080

# Reranker settings. The default model is small and CPU-friendly.
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_DEVICE=cpu

# Extraction settings.
MAX_RESULTS=8
EXTRACT_TOP_K=5
CONTENT_MAX_CHARS=12000
HTTP_TIMEOUT_SECONDS=15

# Optional fallback: self-hosted Jina Reader from the compose "reader" profile.
# If unset or unavailable, local trafilatura extraction is still used.
JINA_READER_BASE_URL=

# Optional hosted Jina Reader fallback. Not true zero-paid if you exceed free quota.
# JINA_READER_BASE_URL=https://r.jina.ai
# JINA_API_KEY=

# Optional summary handoff. Leave empty to return an extractive placeholder.
# Point this at your Cursor/Codex/MiniMax gateway later.
SUMMARY_WEBHOOK_URL=
